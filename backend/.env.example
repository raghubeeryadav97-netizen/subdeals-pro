# Server
PORT=5000
NODE_ENV=development
BASE_URL=http://localhost:5000
FRONTEND_URL=http://localhost:5173

# Database
MONGODB_URI=mongodb://localhost:27017/subdeals-pro

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_EXPIRE=7d
JWT_REFRESH_EXPIRE=30d

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
UPLOAD_PROVIDER=local

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=SubDeals Pro <noreply@subdealspro.com>

# WhatsApp Cloud API (Meta)
WHATSAPP_CLOUD_API_TOKEN=your-whatsapp-cloud-api-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
META_VERIFY_TOKEN=your-meta-verify-token
WHATSAPP_ENABLED=false

# Payment
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key

# Admin
ADMIN_WHATSAPP=919876543210
ADMIN_EMAIL=admin@subdealspro.com

# Company (Invoices)
COMPANY_NAME=SubDeals Pro
COMPANY_ADDRESS=123 Business Park, Mumbai, India
COMPANY_GST=GSTIN123456789
COMPANY_PHONE=+91 98765 43210

# Backup
BACKUP_DIR=./backups
BACKUP_CRON=0 2 * * *